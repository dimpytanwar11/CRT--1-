  //TRAVERSE//MEMORY ADDRESS
#include<iostream>
using namespace std;

void traversal(int arr[], int size){
    for(int i  = 0; i < size; i++){
        cout << arr[i] << " " << "\n";
    }
}
void memoryAdd(int arr[], int size){
    for(int i = 0; i<size; i++){
        cout << &arr[i] << " ";
    }
    
}


int main(){
    int arr[] = {10,20,30,40,50};
    traversal(arr,5);
    memoryAdd(arr, 5);

}


//===============LINEAR SEARCH=================

#include<iostream>
using namespace std;
int LinearSearch(int arr[], int size, int targetValue){
    for(int i = 0; i < size; i++){
        if(arr[i]==targetValue){
            return i;
        }
    }
    return -1;
}

int main(){
    int arr[] = {10,20,30,40,50};
    int targetIndex = LinearSearch(arr, 5, 40);
    cout << targetIndex;
}

//=========================INSERTING AN ELEMENT IN AN ARRAY-------
//ONE PRINTING FUNCTION == WHICH PRINTS THE ARRAY
//ONE INSERTING ELEMENT FUNCTION -- WHICH USES MEMORY ADDRESS OF SIZE BECAUSE WE ARE UPDATING THE SIZE

#include<iostream>
using namespace std;
void printArray(int arr[], int size){
    for(int i = 0; i < size; i++){
        cout << arr[i] << " ";
    }
    cout << "\n";
    
}

 void insertElement(int arr[], int &size, int index, int value){
    for(int i = size; i > index; i--){
        arr[i] = arr[i - 1];
    }
    arr[index] = value;
    size++;
}


int main(){
    int arr[] = {10,20,30,40,50};
    int size = 5;
    insertElement(arr,size,2,25);
    printArray(arr,size);
    
    return 0;
}
