//RECURSION
//consecutibe one's

#include<iostream>
using namespace std;

int consecutiveOnes(int n){
    
    //base
    if(n == 0){
        return 1;
    }
    if(n == 1){
        return 2;
    }
    if(n == 2){
        return 3;
    }
    //logic
   return consecutiveOnes(n - 1) + consecutiveOnes(n - 2);
}

int main(){
    
    cout <<consecutiveOnes(10);
    
    
    return 0;
}

//TILING PROBLEM
#include<iostream>
using namespace std;

int tileComb(int n){
    
    //base
    if(n<4 ){
        return 1;
    }
    
    //logic
   return tileComb(n - 1) + tileComb(n - 4);
}

int main(){
    
    cout <<tileComb(4);
    
    
    return 0;
}
