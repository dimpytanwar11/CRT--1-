//swapping

#include<iostream>
using namespace std;

void swapNumber(int* x, int* y){
    int temp = *x;
    *x = *y;
    *y = temp;
    
}

int main(){
    int a;
    int b;
    cin >> a;
    cin >> b;
    
    swapNumber(&a, &b);
    cout << a << " "  << b;
}

//call by value// callbyref
//value- photocopy
//ref - original
#include<iostream>
using namespace std;

void updatebyValue(int a){
    a = 500;
}
void updatebyReference(int &a){
    a = 500;
}

int main(){
    
    int original = 100;
    cout << original << "\n";
    
    updatebyValue(original);
    cout << original;
    updatebyReference(original);
    cout << original;
    
}

