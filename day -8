}

//POLYMORPHISM--
//Means one name but many forms
//same function behaves differently
//depending on the type of the object it called
//two types
//compile time polymorphism -- function overloading -- static
//resolved at compile time
//function overloads -- same function name, but different parameteriesed
//faster execution
//run time polymorphism -- function overriding -- dynamic
//resolved at run time
//finction runtime -- same function name, same parameters , but different class
//uses a virtual keyword in the base class
//acheiving this through the concept if INHERITANCE


//----compile time----
//----function overloading----

#include<iostream>
using namespace std;

class Math{
public:
    void add(int a, int b){
        cout << a + b << "\n";
    }
public:
    void add(int a, int b, int c){
        cout << a + b + c << "\n";
    }
public:
    void add(double a, double b){
        cout << a + b << "\n";
    }
};

int main(){
    Math m;
    m.add(5,3);
    m.add(2,3,4);
    m.add(3.8,5.6);
    
}

//----run-time----
//function overriding----


class Animal{
public:
    void virtual sound(){
        cout << "animal makes sound" << "\n";
    }
    
};

class Dog : public Animal{
public:
    void sound() override{
        cout << "Dog make a sound"<< "\n";
    }
    
};
class Cat : public Animal{
public:
    void sound() override{
        cout << "cat makes a sound";
    }
    
};

int main(){
    Dog d;
    Cat c;
    d.sound();
    c.sound();
}
