//INHERITANCE
//when a child class possessing a complete property of it parent class, then we can
//say it as inheritance

//single inheritance--
#include<iostream>
using namespace std;

class vehicle{
public:
    void start(){
        cout << "vehicle starts"<< "\n";
    }
};
class car : public  vehicle{
public:
    void drive(){
        cout << "car is running"<< "\n";
    }
    
};

int main(){
    car obj1;
    obj1.drive();
    obj1.start();
    
}


//multi-level inheritance--
#include<iostream>
using namespace std;

class vehicle{
public:
    void start(){
        cout << "vehicle starts"<< "\n";
    }
};
class car : public  vehicle{
public:
    void drive(){
        cout << "car is running"<< "\n";
    }
    
};

class speedoMeter : public car {
public:
    void speed(){
        cout << "car is running at 60km/h" << "\n";
    }
};

int main(){
    speedoMeter obj1;
    obj1.speed();
    obj1.drive();
    obj1.start();
    
}


//hierarchial inheritance
#include<iostream>
using namespace std;

 class vehicle{
public:
    void start(){
        cout << "vehicle starts"<< "\n";
    }
