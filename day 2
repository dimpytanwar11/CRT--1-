//continue statement

#include<iostream>
using namespace std;

int main(){
    int n;
    cin >> n;
    
    for(int i =1; i<=n; i++){
        if(i % 3 == 0){
            continue;
        }
        cout << i << " ";
    }
    cout << "\n";
    
    return 0;
    
}

//break
#include<iostream>
using namespace std;

int main(){
    int n;
    int sum = 0;
    
    while(true){
        cin>> n;
        if(n < 0){
            break;
        }
        sum = sum + n;
    }
    cout << sum;
    return 0;
}

