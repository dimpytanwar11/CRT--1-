// conditional statements
#include<iostream>
using namespace std;

int main(){
    int age;
    cin >> age;
    
    if(age >= 18){
        cout<< "eligible for vote";
    }else{
        cout << "not eligible for vote";
    }
    return 0;
}

// conditional statements
#include<iostream>
using namespace std;

int main(){
    int age;
    cin >> age;
    
    if(age >= 18){
        if(age >=100){
            cout << "we are eligible for vote(but we are super senior citizen)";
        }else{
            cout << "Eligible for vote";
        }
    }else {
        if(age < 0){
            cout << "enter a valid age number";
        }else{
            cout << "not eligible for vote";
        }
    }
        
        
}


// ternary operator

#include<iostream>
using namespace std;

int main(){
    int a,b;
    int max_number;
    
    cin >> a>>b;
    max_number = (a > b) ? a : b;
    
    cout << max_number;
    
    return 0;
    
}


//continue statement

#include<iostream>
using namespace std;

int main(){
    int n;
    cin >> n;
    
    for(int i =1; i<=n; i++){
        if(i % 3 == 0){
            continue;
        }
        cout << i << " ";
    }
    cout << "\n";
    
    return 0;
    
}
