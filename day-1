#include <iostream>
using namespace std;


int main()
{
    double celcius;
    double fahrenheit;
    
    cin >> celcius;
    fahrenheit = (celcius* 9.0/5.0) + 32.0;
    
    std::cout << fahrenheit << std::endl;
     

