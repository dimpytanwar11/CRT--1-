#include <iostream>
using namespace std;


int main()
{
    double celcius;
    double fahrenheit;
    
    cin >> celcius;
    fahrenheit = (celcius* 9.0/5.0) + 32.0;
    
    std::cout << fahrenheit << std::endl;
     

    return 0;
}

// local vs global variables

#include<iostream>
using namespace std;
int globalVariable = 100;
int main(){
    int userInput;
    float result;
    cin >> userInput;
    result = (double)globalVariable / userInput;
    
    cout << result << endl;
}
