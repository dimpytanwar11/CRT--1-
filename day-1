#include<iostream>
using namespace std;

int main(){
    int a;
    int b;
    
    cin >> a >> b;
    int temp = a;
    a = b;
    b = temp;
    
    cout << a << "\n" << b << endl;
    return 0;
}


#include<iostream>
using namespace std;

int main(){
    int choice;
    cin >> choice;
    
    if(choice == 1){
        double radius;
        cin >> radius;
        cout << 3.14 * radius * radius << endl;
    } else if (choice == 2){
        double length , widht;
        cin >> length>> widht;
        cout<< length * widht << endl;
        
    } else if(choice == 3){
        double base, height;
        cin >> base >> height;
        cout << 0.5 * base * height << endl;
    }
    return 0;
}
