//nested loops and pattern printing

#include<iostream>
using namespace std;

int main(){
    for(int i = 1; i <= 10; i++){
        for(int j = 1; j <= 10; j++){
           cout << j << " ";
        }
         cout << "\n";

    }
   


}

#include<iostream>
using namespace std;

int main(){
    for(int i = 1; i <= 10; i++){
        for(int j = 1; j <= 10; j++){
           cout << "*" << " ";
        }
         cout << "\n";

    }
   
}


#include<iostream>
using namespace std;

int main(){
    for(int i =1; i <=6; i++){
        for(int j = 1; j <= i; j++){
            cout << "*" << " ";
            
        }
        cout << "\n";
    }
}

#include<iostream>
using namespace std;

int main(){
    int n;
    cin >> n;
    
    for(int i = 1; i <= n; i++){
        for(int j = n-i; j >= 1; j--){
            cout << " ";
        }
        for(int k = 1; k <= i; k++){
            cout << "*";
        }
        cout << "\n";
    }
}


#include<iostream>
using namespace std;

int main(){
    
    int row, col;
    cin >> row;
    cin>> col;
    
    for(int i = 1; i <= row; i++){
        for(int j = 1; j <= col; j++){
            cout << "*" << " ";
            
        }
        cout << "\n";
    }
}
