//looping

#include<iostream>
using namespace std;

int main(){
    for(int i = 1; i <= 10; i++){
        cout << i << " ";
    }
    return 0;
}


//looping reverse

#include<iostream>
using namespace std;

int main(){
    for(int i = 10; i >= 1; i--){
        cout << i << " ";
    }
    return 0;
}
    
    
    
