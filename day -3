//looping

#include<iostream>
using namespace std;

int main(){
    for(int i = 1; i <= 10; i++){
        cout << i << " ";
    }
    return 0;
}


//looping reverse

#include<iostream>
using namespace std;

int main(){
    for(int i = 10; i >= 1; i--){
        cout << i << " ";
    }
    return 0;
}

//while
#include<iostream>
using namespace std;

int main(){
    int i = 1;
    while(i <= 10){
        cout << i << " ";
        i++;
    }
    return 0;
}
    
//while reverse
#include<iostream>
using namespace std;

int main(){
    int i = 10;
    while(i >= 1){
        cout << i << " ";
        i--;
    }
    return 0;
}


//factorial of a number 

#include<iostream>
using namespace std;

int main(){
    int n;
    cin >> n;
    int fact = 1;
    
    for(int i = n; i >= 1; i --){
        fact = fact * i;
    }
    cout << fact;
    return 0;
}


