//looping

#include<iostream>
using namespace std;

int main(){
    for(int i = 1; i <= 10; i++){
        cout << i << " ";
    }
    return 0;
}


//looping reverse

#include<iostream>
using namespace std;

int main(){
    for(int i = 10; i >= 1; i--){
        cout << i << " ";
    }
    return 0;
}

//while
#include<iostream>
using namespace std;

int main(){
    int i = 1;
    while(i <= 10){
        cout << i << " ";
        i++;
    }
    return 0;
}
    
//while reverse
#include<iostream>
using namespace std;

int main(){
    int i = 10;
    while(i >= 1){
        cout << i << " ";
        i--;
    }
    return 0;
}
